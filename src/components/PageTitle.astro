---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import { Icon } from '@astrojs/starlight/components';

const { id } = Astro.locals.starlightRoute;
const isEnglish = Astro.currentLocale === 'en';
const markdownHref = `${import.meta.env.BASE_URL}/${id}.md`;
// claude.aiに渡すURLは公開サイトの絶対URL（ローカル環境ではclaude.aiから取得できないため）
const markdownUrl = new URL(markdownHref, Astro.site).href;
const claudePrompt = isEnglish
	? `Read ${markdownUrl} so I can ask questions about it.`
	: `${markdownUrl} を読んでください。このページについて質問します。`;
const claudeHref = `https://claude.ai/new?q=${encodeURIComponent(claudePrompt)}`;

const t = isEnglish
	? {
			copyPage: 'Copy page',
			copied: 'Copied!',
			copyMarkdown: 'Copy page as Markdown',
			copyMarkdownDesc: 'Copy this page as Markdown for LLMs',
			viewMarkdown: 'View as Markdown',
			viewMarkdownDesc: 'View this page as plain text',
			openClaude: 'Open in Claude',
			openClaudeDesc: 'Ask questions about this page',
			menuLabel: 'Page actions',
		}
	: {
			copyPage: 'ページをコピー',
			copied: 'コピーしました',
			copyMarkdown: 'Markdownとしてコピー',
			copyMarkdownDesc: 'LLM用にこのページをコピー',
			viewMarkdown: 'Markdownで表示',
			viewMarkdownDesc: 'プレーンテキストで表示',
			openClaude: 'Claudeで開く',
			openClaudeDesc: 'このページについて質問する',
			menuLabel: 'ページ操作',
		};
---

<Default />
<div class="page-actions not-content" data-markdown-href={markdownHref} data-copied-label={t.copied}>
	<div class="split-button">
		<button type="button" class="action-button copy-button" data-copy-markdown>
			<svg class="copy-icon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
				<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
			</svg>
			<svg class="check-icon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="20 6 9 17 4 12"></polyline>
			</svg>
			<span class="copy-label">{t.copyPage}</span>
		</button>
		<button type="button" class="action-button menu-toggle" aria-expanded="false" aria-haspopup="true" aria-label={t.menuLabel}>
			<Icon name="down-caret" size="1.25em" />
		</button>
	</div>
	<div class="menu" hidden>
		<button type="button" class="menu-item" data-copy-markdown>
			<svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
				<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
			</svg>
			<span class="menu-item-text">
				<span class="menu-item-title">{t.copyMarkdown}</span>
				<span class="menu-item-desc">{t.copyMarkdownDesc}</span>
			</span>
		</button>
		<a class="menu-item" href={markdownHref} target="_blank" rel="noopener noreferrer">
			<Icon name="document" size="1em" />
			<span class="menu-item-text">
				<span class="menu-item-title">{t.viewMarkdown}</span>
				<span class="menu-item-desc">{t.viewMarkdownDesc}</span>
			</span>
			<Icon name="external" size="0.875em" class="external-icon" />
		</a>
		<a class="menu-item" href={claudeHref} target="_blank" rel="noopener noreferrer">
			<svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round">
				<line x1="12" y1="12" x2="12" y2="2.5"></line>
				<line x1="12" y1="12" x2="17.5" y2="4.5"></line>
				<line x1="12" y1="12" x2="21" y2="9.5"></line>
				<line x1="12" y1="12" x2="20.5" y2="15.5"></line>
				<line x1="12" y1="12" x2="16.5" y2="20.5"></line>
				<line x1="12" y1="12" x2="11" y2="21.5"></line>
				<line x1="12" y1="12" x2="6" y2="19.5"></line>
				<line x1="12" y1="12" x2="2.5" y2="14.5"></line>
				<line x1="12" y1="12" x2="3.5" y2="8"></line>
				<line x1="12" y1="12" x2="7.5" y2="3.5"></line>
			</svg>
			<span class="menu-item-text">
				<span class="menu-item-title">{t.openClaude}</span>
				<span class="menu-item-desc">{t.openClaudeDesc}</span>
			</span>
			<Icon name="external" size="0.875em" class="external-icon" />
		</a>
	</div>
</div>

<script>
	const root = document.querySelector<HTMLElement>('.page-actions');
	if (root) {
		const markdownHref = root.dataset.markdownHref ?? '';
		const copiedLabel = root.dataset.copiedLabel ?? '';
		const toggle = root.querySelector<HTMLButtonElement>('.menu-toggle')!;
		const menu = root.querySelector<HTMLElement>('.menu')!;
		const copyButton = root.querySelector<HTMLButtonElement>('.copy-button')!;
		const copyLabel = copyButton.querySelector<HTMLElement>('.copy-label')!;
		const defaultLabel = copyLabel.textContent;
		let resetTimer: ReturnType<typeof setTimeout> | undefined;

		const closeMenu = () => {
			menu.hidden = true;
			toggle.setAttribute('aria-expanded', 'false');
		};

		toggle.addEventListener('click', (event) => {
			event.stopPropagation();
			const isOpen = !menu.hidden;
			menu.hidden = isOpen;
			toggle.setAttribute('aria-expanded', String(!isOpen));
		});

		document.addEventListener('click', (event) => {
			if (!menu.hidden && !root.contains(event.target as Node)) closeMenu();
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeMenu();
		});

		// クリック時のawaitでユーザー操作の有効期限が切れないよう、Markdownは事前に取得しておく
		let markdownPromise: Promise<string> | undefined;
		const getMarkdown = () =>
			(markdownPromise ??= fetch(markdownHref).then((response) => {
				if (!response.ok) {
					markdownPromise = undefined;
					throw new Error(`Failed to fetch ${markdownHref}`);
				}
				return response.text();
			}));
		getMarkdown().catch(() => {});

		const copyFallback = (text: string) => {
			const textarea = document.createElement('textarea');
			textarea.value = text;
			textarea.style.position = 'fixed';
			textarea.style.opacity = '0';
			document.body.append(textarea);
			textarea.select();
			const ok = document.execCommand('copy');
			textarea.remove();
			if (!ok) throw new Error('execCommand copy failed');
		};

		const copyMarkdown = async () => {
			const text = await getMarkdown();
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				copyFallback(text);
			}
		};

		for (const button of root.querySelectorAll<HTMLButtonElement>('[data-copy-markdown]')) {
			button.addEventListener('click', async () => {
				closeMenu();
				try {
					await copyMarkdown();
					copyButton.classList.add('copied');
					copyLabel.textContent = copiedLabel;
					clearTimeout(resetTimer);
					resetTimer = setTimeout(() => {
						copyButton.classList.remove('copied');
						copyLabel.textContent = defaultLabel;
					}, 2000);
				} catch (error) {
					console.error(error);
				}
			});
		}
	}
</script>

<style>
	.page-actions {
		position: relative;
		display: inline-block;
		margin-top: 1rem;
		font-size: var(--sl-text-sm);
	}

	.split-button {
		display: inline-flex;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.action-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.4375rem 0.75rem;
		background: transparent;
		border: none;
		color: var(--sl-color-white);
		font: inherit;
		cursor: pointer;
	}

	.action-button:hover {
		background: var(--sl-color-gray-6);
	}

	.menu-toggle {
		padding-inline: 0.375rem;
		border-inline-start: 1px solid var(--sl-color-gray-5);
	}

	.copy-button .check-icon {
		display: none;
		color: var(--sl-color-green);
	}
	.copy-button.copied .check-icon {
		display: inline;
	}
	.copy-button.copied .copy-icon {
		display: none;
	}

	.menu {
		position: absolute;
		inset-inline-start: 0;
		top: calc(100% + 0.375rem);
		z-index: 10;
		min-width: 17rem;
		padding: 0.375rem;
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		box-shadow: var(--sl-shadow-md);
	}

	.menu-item {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		width: 100%;
		padding: 0.5rem 0.625rem;
		background: transparent;
		border: none;
		border-radius: 0.375rem;
		color: var(--sl-color-white);
		font: inherit;
		text-align: start;
		text-decoration: none;
		cursor: pointer;
	}

	.menu-item:hover {
		background: var(--sl-color-gray-6);
	}

	.menu-item :global(svg) {
		flex-shrink: 0;
	}

	.menu-item-text {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		min-width: 0;
	}

	.menu-item-title {
		color: var(--sl-color-white);
	}

	.menu-item-desc {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}

	.external-icon {
		margin-inline-start: auto;
		color: var(--sl-color-gray-3);
	}
</style>

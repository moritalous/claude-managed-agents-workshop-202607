---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import { LinkButton } from '@astrojs/starlight/components';

const { id } = Astro.locals.starlightRoute;
const isEnglish = Astro.currentLocale === 'en';
const markdownHref = `${import.meta.env.BASE_URL}/${id}.md`;
---

<div class="page-title-row">
	<Default />
	<LinkButton href={markdownHref} target="_blank" rel="noopener noreferrer" icon="document" variant="minimal" class="markdown-view-button">
		{isEnglish ? 'View as Markdown' : 'Markdownで表示'}
	</LinkButton>
</div>

<style>
	.page-title-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 1rem;
	}

	.markdown-view-button {
		flex-shrink: 0;
		white-space: nowrap;
	}
</style>
